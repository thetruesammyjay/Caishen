{
  "name": "@caishen/core",
  "version": "1.0.0",
  "description": "Core wallet interfaces, WDK adapters, crypto utilities, policy engine, and unified logger for Caishen",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "tsx": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "tsx src/test-policy.ts"
  },
  "dependencies": {
    "@tetherto/wdk": "1.0.0-beta.6",
    "@tetherto/wdk-protocol-bridge-usdt0-evm": "1.0.0-beta.2",
    "@tetherto/wdk-protocol-lending-aave-evm": "1.0.0-beta.3",
    "@tetherto/wdk-protocol-swap-velora-evm": "1.0.0-beta.4",
    "@tetherto/wdk-wallet-btc": "1.0.0-beta.6",
    "@tetherto/wdk-wallet-evm": "1.0.0-beta.8",
    "@tetherto/wdk-wallet-evm-erc-4337": "1.0.0-beta.5",
    "@tetherto/wdk-wallet-solana": "1.0.0-beta.5",
    "@tetherto/wdk-wallet-ton": "1.0.0-beta.7",
    "@tetherto/wdk-wallet-tron": "1.0.0-beta.4"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
