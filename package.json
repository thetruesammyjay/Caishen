{
  "name": "Caishen",
  "version": "1.0.0",
  "description": "Agentic wallet infrastructure for the Multi-Chain Economy",
  "main": "index.js",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "clean": "pnpm -r exec rimraf dist",
    "verify:production-code": "tsx scripts/verify-production-code.ts",
    "caishen": "tsx packages/cli/src/index.ts",
    "test": "pnpm test:core && pnpm test:cli && pnpm test:cli:contracts && pnpm test:sdk && pnpm test:skills",
    "test:core": "pnpm --filter @caishen/core test",
    "test:cli": "pnpm --filter @caishen/cli build && tsx packages/cli/src/test-cli.ts",
    "test:cli:contracts": "pnpm --filter @caishen/cli build && tsx packages/cli/src/test-cli-contract.ts",
    "test:sdk": "tsx packages/sdk/src/test-sdk.ts",
    "test:skills": "tsx packages/skills/test-skills.ts",
    "demo:agent": "pnpm --filter @caishen/demo-agent start"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "private": "true",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "rimraf": "^6.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
