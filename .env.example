# Caishen environment template
# Copy to .env and set values as needed.
# Most runtime config is stored by `caishen provision` in ~/.caishen/wallet.json.

# ----------------------------------------------------------------------------
# Optional: AI provider settings (for custom agent integrations)
# ----------------------------------------------------------------------------
GROQ_API_KEY=
XAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CAISHEN_MODEL=

# ----------------------------------------------------------------------------
# Network: set to 'testnet' to switch all default RPC endpoints to testnets.
# Testnet mappings:
#   ethereum  → Sepolia (ethereum-sepolia.drpc.org)
#   polygon   → Amoy    (polygon-amoy.drpc.org)
#   arbitrum  → Sepolia (arbitrum-sepolia.drpc.org)
#   tron      → Nile    (nile.trongrid.io)
#   ton       → testnet (testnet.toncenter.com)
#   solana    → Devnet  (api.devnet.solana.com)
#   bitcoin   → testnet (Electrum network: testnet)
# Default: mainnet
# ----------------------------------------------------------------------------
CAISHEN_NETWORK=mainnet
CAISHEN_ACCOUNT_INDEX=0
CAISHEN_ENCRYPTION_PASSPHRASE=

# ----------------------------------------------------------------------------
# Optional: per-chain RPC overrides (applied on top of CAISHEN_NETWORK).
# These override the provider/rpcUrl for the given chain key.
# Format: CAISHEN_RPC_<CHAIN_IN_UPPERCASE>
# Bitcoin uses Electrum — set host/port/protocol via config.wallets, not here.
# ----------------------------------------------------------------------------
CAISHEN_RPC_ETHEREUM=https://eth.drpc.org
CAISHEN_RPC_POLYGON=https://polygon.drpc.org
CAISHEN_RPC_ARBITRUM=https://arbitrum.drpc.org
CAISHEN_RPC_TRON=https://api.trongrid.io
CAISHEN_RPC_TON=https://toncenter.com/api/v2/jsonRPC
CAISHEN_RPC_SOLANA=https://api.mainnet-beta.solana.com
